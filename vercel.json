{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/reminders",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/associations",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/interview",
      "schedule": "30 19 * * *"
    },
    {
      "path": "/api/cron/weather_morning",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/weather_check",
      "schedule": "0 12 * * *"
    }
  ]
}